---
import { algorithms } from '../data/algorithms';

interface Props {
  slug: string;
  name: string;
  description: string;
  color: string;
}

const { slug, name, description, color } = Astro.props;

const count = algorithms.filter(a => a.categorySlug === slug).length;

const iconMap: Record<string, string> = {
  green: '⚡',
  blue: '🧩',
  purple: '✂️',
  red: '↩️',
  teal: '🕸️',
};

const bgMap: Record<string, string> = {
  green: 'bg-brand-950 border-brand-800 hover:border-brand-600',
  blue: 'bg-blue-950 border-blue-800 hover:border-blue-600',
  purple: 'bg-purple-950 border-purple-800 hover:border-purple-600',
  red: 'bg-red-950 border-red-800 hover:border-red-600',
  teal: 'bg-teal-950 border-teal-800 hover:border-teal-600',
};

const textMap: Record<string, string> = {
  green: 'text-brand-400',
  blue: 'text-blue-400',
  purple: 'text-purple-400',
  red: 'text-red-400',
  teal: 'text-teal-400',
};
---

<a
  href={`/categories/${slug}`}
  class={`${bgMap[color]} border rounded-xl p-6 block transition-all duration-200 hover:-translate-y-0.5`}
>
  <div class="text-3xl mb-3">{iconMap[color]}</div>
  <h3 class={`font-bold text-lg mb-2 ${textMap[color]}`}>{name}</h3>
  <p class="text-dark-400 text-sm leading-relaxed mb-4">{description}</p>
  <div class="text-dark-500 text-xs font-medium">{count} algorithm{count !== 1 ? 's' : ''}</div>
</a>
