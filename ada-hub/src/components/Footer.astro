---
import { algorithms } from '../data/algorithms';

const featured = algorithms.slice(0, 6);
---

<footer class="bg-dark-950 border-t border-dark-800 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center font-bold text-white font-mono text-sm">A</div>
          <span class="font-bold text-dark-50 text-lg">ADA Hub</span>
        </a>
        <p class="text-dark-500 text-sm leading-relaxed">
          A comprehensive learning portal for Analysis and Design of Algorithms — VTU BCSL40A lab programs and beyond.
        </p>
        <div class="flex items-center gap-3 mt-4">
          <a href="https://rajathkiran.me/" target="_blank" rel="noopener noreferrer" class="text-dark-500 hover:text-brand-400 transition-colors" aria-label="Portfolio">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
            </svg>
          </a>
          <a href="https://github.com/Rajath2005" target="_blank" rel="noopener noreferrer" class="text-dark-500 hover:text-brand-400 transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Algorithms -->
      <div>
        <h3 class="font-semibold text-dark-100 mb-4">Algorithms</h3>
        <ul class="space-y-2">
          {featured.map(algo => (
            <li>
              <a href={`/algorithms/${algo.slug}`} class="text-dark-500 hover:text-brand-400 text-sm transition-colors">
                {algo.shortTitle}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Categories -->
      <div>
        <h3 class="font-semibold text-dark-100 mb-4">Categories</h3>
        <ul class="space-y-2">
          <li><a href="/categories/greedy" class="text-dark-500 hover:text-brand-400 text-sm transition-colors">Greedy Algorithms</a></li>
          <li><a href="/categories/dynamic-programming" class="text-dark-500 hover:text-brand-400 text-sm transition-colors">Dynamic Programming</a></li>
          <li><a href="/categories/divide-and-conquer" class="text-dark-500 hover:text-brand-400 text-sm transition-colors">Divide and Conquer</a></li>
          <li><a href="/categories/backtracking" class="text-dark-500 hover:text-brand-400 text-sm transition-colors">Backtracking</a></li>
          <li><a href="/categories/graph-algorithms" class="text-dark-500 hover:text-brand-400 text-sm transition-colors">Graph Algorithms</a></li>
          <li><a href="/blog" class="text-dark-500 hover:text-brand-400 text-sm transition-colors">Blog</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="font-semibold text-dark-100 mb-4">Resources</h3>
        <ul class="space-y-2">
          <li>
            <a href="https://rajathkiran.me/" target="_blank" rel="noopener noreferrer" class="text-brand-400 hover:text-brand-300 text-sm transition-colors font-medium">
              🌐 rajathkiran.me ↗
            </a>
          </li>
          <li><a href="https://github.com/Rajath2005/Analysis-and-Design-of-Algorithms" target="_blank" rel="noopener noreferrer" class="text-dark-500 hover:text-brand-400 text-sm transition-colors">GitHub Repository ↗</a></li>
          <li><a href="/about" class="text-dark-500 hover:text-brand-400 text-sm transition-colors">About the Author</a></li>
          <li><a href="/rss.xml" class="text-dark-500 hover:text-brand-400 text-sm transition-colors">RSS Feed</a></li>
          <li><a href="/sitemap-index.xml" class="text-dark-500 hover:text-brand-400 text-sm transition-colors">Sitemap</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-dark-800 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-dark-600 text-sm">
        © {new Date().getFullYear()} ADA Hub · Built by <a href="https://rajathkiran.me/" class="text-brand-500 hover:text-brand-400 font-medium" target="_blank" rel="noopener noreferrer">Rajath Kiran A</a>
      </p>
      <p class="text-dark-600 text-sm">
        VTU BCSL40A · Analysis and Design of Algorithms
      </p>
    </div>
  </div>
</footer>
