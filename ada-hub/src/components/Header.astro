---
const navLinks = [
  { href: '/algorithms', label: 'Algorithms' },
  { href: '/categories', label: 'Categories' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-dark-900/95 backdrop-blur-sm border-b border-dark-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-8 h-8 bg-brand-600 rounded-lg flex items-center justify-center font-bold text-white font-mono text-sm group-hover:bg-brand-500 transition-colors">
          A
        </div>
        <div class="hidden sm:block">
          <span class="font-bold text-dark-50 text-lg">ADA Hub</span>
          <span class="hidden md:inline text-dark-500 text-sm ml-2">/ Algorithms Portal</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              currentPath.startsWith(link.href)
                ? 'bg-dark-800 text-brand-400'
                : 'text-dark-400 hover:text-dark-100 hover:bg-dark-800'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="https://github.com/Rajath2005/Analysis-and-Design-of-Algorithms"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-2 flex items-center gap-2 px-4 py-2 bg-dark-800 hover:bg-dark-700 border border-dark-700 text-dark-200 rounded-lg text-sm font-medium transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-dark-400 hover:text-dark-100 hover:bg-dark-800 transition-colors"
        aria-label="Open menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-dark-800 bg-dark-900">
    <div class="px-4 py-3 space-y-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`block px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
            currentPath.startsWith(link.href)
              ? 'bg-dark-800 text-brand-400'
              : 'text-dark-400 hover:text-dark-100 hover:bg-dark-800'
          }`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/Rajath2005/Analysis-and-Design-of-Algorithms"
        target="_blank"
        rel="noopener noreferrer"
        class="block px-3 py-2 text-dark-400 hover:text-dark-100 text-sm font-medium"
      >
        ⭐ GitHub Repository
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
