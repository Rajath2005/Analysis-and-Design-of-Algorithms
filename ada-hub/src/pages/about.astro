---
import BaseLayout from '../layouts/BaseLayout.astro';
import GitHubStats from '../components/GitHubStats.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { algorithms } from '../data/algorithms';
---

<BaseLayout
  title="About Rajath Kiran A — ADA Hub Author"
  description="Rajath Kiran A is a Computer Science student who built ADA Hub — a comprehensive learning portal for Analysis and Design of Algorithms with all VTU BCSL40A lab programs."
  keywords={['Rajath Kiran A', 'ADA hub author', 'vtu computer science student', 'algorithm developer']}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb crumbs={[{ label: 'About' }]} />

    <!-- Profile -->
    <div class="card p-8 mb-10">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6">
        <div class="w-24 h-24 bg-gradient-to-br from-brand-500 to-brand-800 rounded-2xl flex items-center justify-center text-white font-bold text-4xl shrink-0">
          R
        </div>
        <div class="text-center sm:text-left">
          <h1 class="text-3xl font-bold text-dark-50 mb-1">Rajath Kiran A</h1>
          <p class="text-brand-400 font-medium mb-3">Computer Science Student · Open Source Developer</p>
          <p class="text-dark-400 leading-relaxed max-w-2xl">
            Passionate about algorithms, data structures, and making computer science accessible to everyone. 
            I built ADA Hub to help fellow students master the Analysis and Design of Algorithms course at VTU.
          </p>
          <div class="flex flex-wrap items-center gap-3 mt-5 justify-center sm:justify-start">
            <a href="https://github.com/Rajath2005" target="_blank" rel="noopener noreferrer" class="btn-primary text-sm py-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              @Rajath2005
            </a>
            <a href="https://github.com/Rajath2005/Analysis-and-Design-of-Algorithms" target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm py-2">
              ADA Repository ↗
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-8">
        <!-- About the Project -->
        <section>
          <h2 class="text-2xl font-bold text-dark-50 mb-4">About This Project</h2>
          <div class="prose-content space-y-4 text-dark-300 leading-relaxed">
            <p>
              ADA Hub was created to solve a real problem: finding clear, complete, and well-explained ADA lab programs in C is surprisingly difficult. Most resources online are incomplete, poorly formatted, or lack the depth needed for VTU exams.
            </p>
            <p>
              This portal provides all <strong class="text-dark-100">{algorithms.length} VTU BCSL40A programs</strong> with:
            </p>
            <ul class="list-disc list-inside space-y-2 ml-4">
              <li>Complete, working C source code</li>
              <li>Detailed algorithm explanations</li>
              <li>Step-by-step procedure</li>
              <li>Sample input and expected output</li>
              <li>Dry run / trace-through</li>
              <li>Time and space complexity analysis</li>
              <li>Viva questions and answers</li>
              <li>Real-world applications</li>
            </ul>
          </div>
        </section>

        <!-- Skills -->
        <section>
          <h2 class="text-2xl font-bold text-dark-50 mb-4">Technical Skills</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {['C Programming', 'C++', 'Data Structures', 'Algorithms', 'Python', 'Web Development', 'Git & GitHub', 'Linux', 'LaTeX'].map(skill => (
              <div class="bg-dark-800 border border-dark-700 rounded-lg px-4 py-2.5 text-dark-300 text-sm font-medium text-center hover:border-brand-700 transition-colors">
                {skill}
              </div>
            ))}
          </div>
        </section>

        <!-- Projects -->
        <section>
          <h2 class="text-2xl font-bold text-dark-50 mb-4">Projects</h2>
          <div class="space-y-4">
            <div class="card p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-semibold text-dark-100 mb-1">ADA Lab Programs Repository</h3>
                  <p class="text-dark-400 text-sm leading-relaxed">Complete implementation of all 13 VTU BCSL40A ADA Lab programs in C with documentation, sample outputs, and time complexity graphs.</p>
                  <div class="flex flex-wrap gap-2 mt-3">
                    <span class="badge badge-green">C</span>
                    <span class="badge bg-dark-700 text-dark-300 border border-dark-600">Algorithms</span>
                    <span class="badge bg-dark-700 text-dark-300 border border-dark-600">VTU</span>
                  </div>
                </div>
                <a href="https://github.com/Rajath2005/Analysis-and-Design-of-Algorithms" target="_blank" rel="noopener noreferrer" class="shrink-0 btn-secondary text-xs py-1.5 px-3">View ↗</a>
              </div>
            </div>
            <div class="card p-5">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-semibold text-dark-100 mb-1">ADA Hub — This Website</h3>
                  <p class="text-dark-400 text-sm leading-relaxed">A production-ready educational portal built with Astro, Tailwind CSS, and TypeScript. SEO-optimized with structured data, sitemap, and RSS feed.</p>
                  <div class="flex flex-wrap gap-2 mt-3">
                    <span class="badge badge-blue">Astro</span>
                    <span class="badge bg-dark-700 text-dark-300 border border-dark-600">TypeScript</span>
                    <span class="badge bg-dark-700 text-dark-300 border border-dark-600">Tailwind</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>

      <aside>
        <h2 class="text-xl font-bold text-dark-50 mb-4">Repository Stats</h2>
        <GitHubStats />

        <div class="mt-6 card p-5">
          <h3 class="font-semibold text-dark-100 mb-3">Quick Links</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/algorithms" class="text-brand-400 hover:text-brand-300">→ All Algorithms</a></li>
            <li><a href="/categories" class="text-brand-400 hover:text-brand-300">→ Browse Categories</a></li>
            <li><a href="/blog" class="text-brand-400 hover:text-brand-300">→ Algorithm Articles</a></li>
            <li><a href="https://github.com/Rajath2005" target="_blank" rel="noopener noreferrer" class="text-brand-400 hover:text-brand-300">→ GitHub Profile ↗</a></li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
